@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@using System.Text.Json
@using System.Text.Json.Serialization

<PageTitle>Conway's World</PageTitle>

@* Inline critical CSS so it loads from the fresh DLL, bypassing app.css caching. *@
<style>
    .cw-settings-grid{display:grid;grid-template-columns:1fr 1fr;column-gap:16px}
    .cw-settings-grid>h3,.cw-settings-grid>.cw-field-full{grid-column:1/-1}
    .cw-settings-section{grid-column:1/-1}
</style>

<div class="cw-toolbar">
    <button class="@(_running ? "active" : "")" @onclick="TogglePlay">
        @(_running ? "⏸ Pause" : "▶ Play")
    </button>
    <button @onclick="StepOnce">Step</button>
    <button @onclick="Restart">↺ Restart</button>
    <button @onclick="RandomizeAndRestart">🎲 Random</button>
    <label>Speed</label>
    <input type="range" min="50" max="2000" step="50"
           value="@_intervalMs"
           @onchange="OnSpeedChange" />
    <input type="number" min="50" max="10000" step="50"
           value="@_intervalMs"
           @onchange="OnSpeedInputChange"
           style="width:64px;background:#1a1a1a;border:1px solid #333;color:#aaa;font-size:11px;padding:1px 4px;border-radius:3px;text-align:right" />
    <span style="color:#888;font-size:11px">ms</span>

    <button @onclick="() => _showSettings = true">⚙ Settings</button>
    <button @onclick="() => { _showTestCases = true; _selectedTestCase = 0; }">🧪 Test Cases</button>
    <button title="Toggle fullscreen (F)" @onclick="ToggleFullscreen">@(_isFullscreen ? "⊡ Exit Full" : "⛶ Full")</button>
    <span style="margin-left:auto;color:#666;font-size:11px">
        Gen @_model.Generation &nbsp;|&nbsp;
        Pop @_model.CurrentPopulation &nbsp;|&nbsp;
        Grid @_model.Columns×@_model.Rows
    </span>
</div>

<div class="cw-body">
    <div class="cw-main">
        <div class="cw-canvas-wrap" id="canvas-wrap">
            <canvas id="sim-canvas"></canvas>
            @if (_tooltip != null)
            {
                <div class="cw-tooltip" style="left:@(_tooltipX)px;top:@(_tooltipY)px">
                    <div class="tt-type">@_tooltip.TypeName</div>
                    <div class="tt-row">Nation @(_tooltip.Nation >= 0 ? _tooltip.Nation.ToString() : "—")</div>
                    <div class="tt-row">Age @_tooltip.Age</div>
                    @if (_tooltip.Conditions.Length > 0)
                    {
                        <div class="tt-row" style="font-size:10px;color:#777">@_tooltip.Conditions</div>
                    }
                </div>
            }
        </div>

        <div class="cw-event-bar">
            <button class="cw-log-toggle" @onclick="() => _showEventLog = !_showEventLog">
                @(_showEventLog ? "▾ Events" : "▸ Events")
                @if (_eventLog.Count > 0 && !_showEventLog)
                {
                    <span class="cw-log-badge">@_eventLog.Count</span>
                }
            </button>
        </div>
        @if (_showEventLog)
        {
            <div class="cw-event-log">
                @foreach (var ev in _eventLog)
                {
                    <div class="cw-event-entry @ev.CssClass">@ev.Message</div>
                }
            </div>
        }
    </div>

    <div class="cw-sidebar">
        <div class="cw-content-area">
            <div class="cw-panel">
                <h3>Cell Types</h3>
                <div class="cw-cell-list">
                    @foreach (var entry in _typeCounts)
                    {
                        <div class="cw-cell-row" title="@(CellDescriptions.GetValueOrDefault(entry.Name, ""))">
                            <img class="cw-cell-sprite" src="Assets/Sprites/Cell_@(entry.Name).jpg" alt="@entry.Name" />
                            <span>@entry.Name</span>
                            <span class="cw-cell-count">@entry.Count</span>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<div class="cw-nations-bar">
    @{var nlist = _model.Nations.Values.Where(n => n.CitizensList.Count > 0).OrderBy(n => n.NationNum).ToList();}
    @for (int ni = 0; ni < nlist.Count; ni++)
    {
        var n = nlist[ni];
        if (ni > 0) { <span class="cw-nation-sep"> | </span> }
        <span class="cw-nation-count" style="color:@Cell_Nation.NationColors[n.NationNum % Cell_Nation.NationColors.Count]">@n.CitizensList.Count</span>
    }
</div>

@if (_showFailurePopup)
{
    <div class="cw-modal-overlay" @onclick="() => _showFailurePopup = false">
        <div class="cw-extinct-popup" @onclick:stopPropagation>
            <div class="cw-extinct-icon">@_failureIcon</div>
            <div class="cw-extinct-title">@_failureTitle</div>
            <div class="cw-extinct-sub">@_failureMessage</div>
            @if (!string.IsNullOrEmpty(_failureStats))
            {
                <div class="cw-extinct-stats">@_failureStats</div>
            }
            <button class="cw-extinct-btn" @onclick="() => _showFailurePopup = false">Dismiss</button>
        </div>
    </div>
}



@if (_showSettings)
{
    <div class="cw-modal-overlay" @onclick="() => _showSettings = false">
        <div class="cw-modal" @onclick:stopPropagation>
            <div class="cw-modal-header">
                <span>Settings</span>
                <button class="cw-modal-close" @onclick="() => _showSettings = false">✕</button>
            </div>
            <div class="cw-modal-tabs">
                <button class="cw-modal-tab @(_settingsTab == 0 ? "cw-modal-tab-active" : "")"
                        @onclick="() => _settingsTab = 0">General</button>
                <button class="cw-modal-tab @(_settingsTab == 1 ? "cw-modal-tab-active" : "")"
                        @onclick="() => _settingsTab = 1">Spawn Weights</button>
                <button class="cw-modal-tab @(_settingsTab == 2 ? "cw-modal-tab-active" : "")"
                        @onclick="() => _settingsTab = 2">Hotkeys</button>
                <button class="cw-modal-tab @(_settingsTab == 3 ? "cw-modal-tab-active" : "")"
                        @onclick="() => _settingsTab = 3">Rules</button>
            </div>
            <div class="cw-settings-scroll">
                @if (_settingsTab == 0)
                {
                    <div class="cw-settings-grid">
                        <div class="cw-field" title="Width of the starting grid in cells (5–300). Larger grids use more CPU.">
                            <label>Start columns</label>
                            <input type="number" min="5" max="300" @bind="_startCols" />
                        </div>
                        <div class="cw-field" title="Height of the starting grid in cells (5–300).">
                            <label>Start rows</label>
                            <input type="number" min="5" max="300" @bind="_startRows" />
                        </div>
                        <div class="cw-field" title="Maximum grid dimension after expansion. Set to 0 for no limit. The grid grows when Explorer cells reach an edge.">
                            <label>Max grid size (0 = unlimited)</label>
                            <input type="number" min="0" max="500" @bind="_maxGrid" />
                        </div>
                        <div class="cw-field" title="Maximum number of distinct nations that can coexist (1–20). Kings and Diplomats appear only when multiple nations are active.">
                            <label>Max nations (1–20)</label>
                            <input type="number" min="1" max="20" @bind="_maxNations" />
                        </div>
                        <div class="cw-field" title="Number of initial cell clusters placed at startup. Set to 0 to use MaxNations ÷ 4 automatically.">
                            <label>Start clusters (0 = MaxNations ÷ 4)</label>
                            <input type="number" min="0" max="20" @bind="_startClusters" />
                        </div>
                        <div class="cw-field" title="Toggle smooth movement animations for Traveler, Explorer, Spy, and other moving cell types.">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_animationEnabled" />
                                Movement animation
                            </label>
                        </div>
                        <div class="cw-field cw-field-full" title="How many cells are placed at the start of each run, expressed as a percentage of the grid or a fixed cell count.">
                            <label>Initial population</label>
                            <div class="cw-pop-fields">
                                <input type="number" class="cw-pop-input" min="0" max="100" step="0.1"
                                       value="@_popPercent.ToString("F1")"
                                       @onchange="OnPopPercentChange"
                                       @onkeydown="@(e => { if (e.Key == "Enter") OnPopPercentChange(new ChangeEventArgs { Value = _popPercentStr }); })" />
                                <span class="cw-pop-sep">%</span>
                                <input type="number" class="cw-pop-input" min="0" max="@(_startCols * _startRows)"
                                       value="@_popCount"
                                       @onchange="OnPopCountChange"
                                       @onkeydown="@(e => { if (e.Key == "Enter") OnPopCountChange(new ChangeEventArgs { Value = _popCount.ToString() }); })" />
                                <span class="cw-pop-sep">/ @(_startCols * _startRows)</span>
                            </div>
                        </div>

                        <h3 class="cw-settings-section">Conway Rules</h3>
                        <div class="cw-field" title="Minimum live neighbours a cell needs to survive, and minimum neighbours an empty cell needs to be born. Standard Conway value is 2.">
                            <label>Min neighbors (survive &amp; birth)</label>
                            <input type="number" min="0" max="7" @bind="_minNeighbors" />
                        </div>
                        <div class="cw-field" title="Maximum live neighbours a cell can have and still survive. Cells with more neighbours die of overcrowding. Standard Conway value is 3.">
                            <label>Max neighbors (survive)</label>
                            <input type="number" min="0" max="8" @bind="_maxNeighbors" />
                        </div>

                        <h3 class="cw-settings-section">World Events</h3>
                        <div class="cw-field" title="Periodically kills cells in a random grid quadrant, simulating a food shortage. Controlled by Cooldown and Duration settings below.">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_famineEnabled" />
                                Enable Famine
                            </label>
                        </div>
                        <div class="cw-field" title="Periodically wipes the outer border ring of the grid, separating nation clusters and resetting expansion pressure.">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_floodEnabled" />
                                Enable Flood
                            </label>
                        </div>
                        @if (_famineEnabled)
                        {
                            <div class="cw-field" title="Minimum number of simulation steps that must pass before the next famine event can occur.">
                                <label>Min steps between famines</label>
                                <input type="number" min="1" max="500" @bind="_famineCooldown" />
                            </div>
                            <div class="cw-field" title="How many simulation steps a single famine event lasts.">
                                <label>Famine duration (steps)</label>
                                <input type="number" min="1" max="100" @bind="_famineDuration" />
                            </div>
                        }
                        <div class="cw-field" title="When population falls below the injection threshold, random cells are spawned to prevent total extinction.">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_randomLifeEnabled" />
                                Random Life Injection
                            </label>
                        </div>
                        <div class="cw-field cw-field-full" title="Population level (as % of grid or absolute count) below which new random cells are injected.">
                            <label>Inject when pop falls below</label>
                            <div class="cw-pop-fields">
                                <input type="number" class="cw-pop-input" min="0" max="100" step="0.1"
                                       value="@_randomLifeThresholdPct.ToString("F1")"
                                       @onchange="OnRandomLifeThresholdPctChange"
                                       @onkeydown="@(e => { if (e.Key == "Enter") OnRandomLifeThresholdPctChange(new ChangeEventArgs { Value = _randomLifeThresholdPctStr }); })" />
                                <span class="cw-pop-sep">%</span>
                                <input type="number" class="cw-pop-input" min="0" max="@(_startCols * _startRows)"
                                       value="@_randomLifeThresholdCount"
                                       @onchange="OnRandomLifeThresholdCountChange"
                                       @onkeydown="@(e => { if (e.Key == "Enter") OnRandomLifeThresholdCountChange(new ChangeEventArgs { Value = _randomLifeThresholdCount.ToString() }); })" />
                                <span class="cw-pop-sep">/ @(_startCols * _startRows)</span>
                            </div>
                        </div>
                        <div class="cw-field" title="Allow Explorer cells to expand the grid beyond its starting size, up to the Max Grid Size limit.">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_allowGridExpansion" />
                                Allow grid expansion
                            </label>
                        </div>
                        <div class="cw-field" title="Enable the full nation system: proximity-based nationality, King crowning, Diplomat election, and Revolutionary defection.">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_nationsEnabled" />
                                Enable nations &amp; kings
                            </label>
                        </div>

                        <h3 class="cw-settings-section cw-field-full">Failure Conditions</h3>
                        <div class="cw-field" title="Simulation ends if population drops to or below this count. Set to 0 to disable.">
                            <label>Min pop threshold (0 = off)</label>
                            <input type="number" min="0" max="10000" @bind="_failurePopThreshold" />
                        </div>
                        <div class="cw-field" title="Simulation ends if population collapses back below this count after previously growing above it. Set to 0 to disable.">
                            <label>Min pop after growth (0 = off)</label>
                            <input type="number" min="0" max="10000" @bind="_failurePopAfterGrowthThreshold" />
                        </div>
                        <div class="cw-field" title="Simulation ends if population stays at exactly the same count for this many consecutive steps. Set to 0 to disable.">
                            <label>Stagnation steps (0 = off)</label>
                            <input type="number" min="0" max="500" @bind="_stagnationSteps" />
                        </div>
                        <div class="cw-field cw-field-full" title="Automatically restart the simulation when a failure condition triggers, instead of showing the failure popup.">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_autoContinue" />
                                Auto-restart on failure
                            </label>
                        </div>
                    </div>
                }
                else if (_settingsTab == 1)
                {
                    <div class="cw-weights-grid">
                        @foreach (var kv in _spawnWeights)
                        {
                            <div class="cw-weight-row" title="@(CellDescriptions.GetValueOrDefault(kv.Key, ""))">
                                <img class="cw-cell-sprite" src="Assets/Sprites/Cell_@(kv.Key).jpg" alt="@kv.Key" />
                                <span class="cw-weight-name">@kv.Key</span>
                                <input type="number" min="0" max="100"
                                       value="@kv.Value"
                                       @onchange="@(e => OnWeightChange(kv.Key, e))" />
                            </div>
                        }
                    </div>
                }
                else if (_settingsTab == 2)
                {
                    <table class="cw-hotkeys-table">
                        <thead>
                            <tr><th>Key / Input</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><kbd>Space</kbd></td><td>Play / Pause</td></tr>
                            <tr><td><kbd>R</kbd></td><td>Restart simulation</td></tr>
                            <tr><td><kbd>Escape</kbd></td><td>Close open modal</td></tr>
                            <tr><td><kbd>F</kbd></td><td>Toggle fullscreen</td></tr>
                            <tr><td><kbd>Scroll wheel</kbd></td><td>Zoom in / out</td></tr>
                            <tr><td><kbd>Right-click drag</kbd></td><td>Pan the grid</td></tr>
                            <tr><td><kbd>Double-click</kbd></td><td>Reset zoom &amp; pan</td></tr>
                            <tr><td><kbd>Left-click</kbd></td><td>Select a cell (shows events)</td></tr>
                            <tr><td><kbd>Hover</kbd></td><td>Tooltip: type, nation, age, conditions</td></tr>
                        </tbody>
                    </table>
                }
                else if (_settingsTab == 3)
                {
                    <div class="cw-rules-list">
                        <h3 class="cw-rules-section-head">Cell Types</h3>
                        @foreach (var (name, desc) in CellRules)
                        {
                            <div class="cw-rules-entry">
                                <div class="cw-sprite-wrap">
                                    <img class="cw-cell-sprite" src="Assets/Sprites/Cell_@(name).jpg" alt="@name" />
                                    <img class="cw-sprite-zoom-popup" src="Assets/Sprites/Cell_@(name).jpg" alt="" />
                                </div>
                                <div class="cw-rules-text">
                                    <span class="cw-rules-name">@name</span>
                                    <span class="cw-rules-desc">@desc</span>
                                </div>
                            </div>
                        }
                        <h3 class="cw-rules-section-head" style="margin-top:14px">Simulation Mechanics</h3>
                        @foreach (var (label, desc) in SimulationEvents)
                        {
                            <div class="cw-rules-entry cw-rules-event">
                                <div class="cw-rules-text">
                                    <span class="cw-rules-name">@label</span>
                                    <span class="cw-rules-desc">@desc</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            @if (_settingsTab != 3)
            {
                <div class="cw-modal-footer">
                    <button class="cw-apply-btn" style="flex:1" @onclick="ApplyAndRestart">Apply & Restart</button>
                    <button class="cw-apply-btn" style="flex:1;background:#555" @onclick="ResetToDefaults">Reset Defaults</button>
                </div>
            }
        </div>
    </div>
}

@if (_showTestCases)
{
    <div class="cw-modal-overlay" @onclick="() => _showTestCases = false">
        <div class="cw-modal cw-tc-modal" @onclick:stopPropagation>
            <div class="cw-modal-header">
                <span>Test Cases</span>
                <button class="cw-modal-close" @onclick="() => _showTestCases = false">✕</button>
            </div>
            <div class="cw-tc-list">
                @for (int i = 0; i < _testCases.Count; i++)
                {
                    var tc = _testCases[i];
                    var idx = i;
                    <div class="cw-tc-row @(_selectedTestCase == idx ? "cw-tc-selected" : "")"
                         @onclick="() => _selectedTestCase = idx">
                        <div class="cw-tc-name">@tc.Name</div>
                        <div class="cw-tc-desc">@tc.Description</div>
                        @if (_selectedTestCase == idx)
                        {
                            <div class="cw-tc-detail">
                                Grid @tc.StartCols×@tc.StartRows &nbsp;·&nbsp;
                                Max @tc.MaxGrid &nbsp;·&nbsp;
                                Nations @tc.MaxNations &nbsp;·&nbsp;
                                Clusters @tc.StartClusters &nbsp;·&nbsp;
                                Pop @tc.PopCount
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="cw-modal-footer">
                <button class="cw-apply-btn" style="flex:1" @onclick="ApplyTestCase">Apply to Settings</button>
                <button class="cw-apply-btn" style="flex:1;background:#555" @onclick="() => _showTestCases = false">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private Model _model = null!;
    private SimulationSettings _settings = new();
    private System.Timers.Timer _timer = null!;
    private DotNetObjectReference<Index>? _dotNetRef;
    private bool _running = false;
    private bool _showSettings = false;
    private bool _showTestCases = false;
    private bool _isFullscreen = false;
    private int _selectedTestCase = 0;
    private int _settingsTab = 0;
    private int _intervalMs = 1000;
    private bool _animationEnabled = true;
    private bool _canvasReady = false;

    private Dictionary<(int col, int row), (int type, int nat)> _prevCellMap = new();

    private List<(string Name, string Color, int Count)> _typeCounts = new();

    private record TooltipData(string TypeName, int Nation, int Age, string Conditions);
    private TooltipData? _tooltip;
    private double _tooltipX = 0, _tooltipY = 0;

    private record SimEvent(string Message, string CssClass);
    private List<SimEvent> _eventLog = new();
    private const int MaxEventLog = 60;
    private bool _showEventLog = false;

    // ── In-app documentation ────────────────────────────────────────────────────
    private static readonly (string Name, string Desc)[] CellRules =
    {
        ("Basic",          "Standard Conway cells. 25% immune chance; 1% born immaculate (cannot be infected)."),
        ("Immortal",       "Lives forever unless isolated for more than 8 consecutive steps. Immune to all disease strains."),
        ("Diseased",       "Spreads the d_ infection strain to neighbours each step; dies after a 3-step countdown."),
        ("Plague",         "Like Diseased but 40% higher transmission rate; spreads the p_ strain."),
        ("Traveler",       "Moves one cell per step; dies if isolated more than 3 steps or fully surrounded for more than 3 steps."),
        ("Explorer",       "Like Traveler; triggers grid expansion when it reaches an edge."),
        ("Doctor",         "Cures disease in adjacent cells; stamps vax_ immunity markers to prevent re-infection; survives while actively vaccinating."),
        ("Warrior",        "Fights foreign Diseased/Plague within range 2; hunts Saviors, Followers, and Rebels of any nation; demotes to Basic after 3 idle steps."),
        ("Hunter",         "Hunts Immortals and Kings within range 5; also hunts Saviors, Followers, and Rebels of any nation; demotes to Basic after 3 idle steps."),
        ("Bomber",         "Always nationless. Detonates at age 2, destroying all cells within a 2-cell radius."),
        ("Diplomat",       "Elected from large nations; travels to the nearest foreign nation and converts adjacent cells to its own nationality."),
        ("King",           "Crowned when a nation reaches ≥5 citizens. Marks neighbouring Basic cells with toWar, promoting them to Warriors. Death triggers a neutralisation cooldown for distant cells."),
        ("Rebel",          "Short-lived Diplomat variant with 3× conversion rate; hunted by Warriors and Hunters of all nations."),
        ("Revolutionary",  "Defects from the dominant nation, founds a rival nation, and recruits Warriors and Rebels from the old homeland."),
        ("Voyager",        "Travels to a disconnected foreign nation. On arrival: 50% spawns Diplomats and Warriors, 50% seeds 4 Plague cells."),
        ("Wayfinder",      "Finds the emptiest grid region and travels there. On arrival spawns 5 Islanders. Dies if ≥20 cells crowd within 5 tiles."),
        ("Islander",       "Nationless; lives by Conway rules; dies from overcrowding (≥20 within 5 tiles); converts to Barbarian when touched by a nation cell."),
        ("Barbarian",      "Nationless aggressor. Converts adjacent Islanders and kills nearby nation cells; reverts to Islander when no targets remain."),
        ("Spy",            "Infiltrates enemy territory from a minority nation; swaps through living cells, converting each displaced cell into a Soldier."),
        ("Soldier",        "Combat cell created by Spies and Conquistadors. Kills adjacent enemies; advances on distant ones; triggers a nation-merge check when its wave is wiped out."),
        ("Conquistador",   "Like Voyager but on arrival teleports the 10 nearest home-nation cells to the landing zone and converts them all (plus itself) into Soldiers."),
        ("Savior",         "At most one per grid. Flees toward a foreign nation, converting adjacent Basic cells into Followers. On reaching the target King: 50% assimilates (Immortal), 50% dies (→ Zealots). Hunted by all Warriors/Hunters."),
        ("Follower",       "Created by a Savior. Waits 3 steps then follows the Savior's last broadcast direction. Reverts to Basic after 4 consecutive blocked steps. Hunted by all Warriors/Hunters."),
        ("Zealot",         "Created when a Savior dies. Attacks any adjacent living cell regardless of nation; advances toward the nearest living cell when idle."),
        ("Irradiated",     "Permanent hazard tile. Kills any cell that swaps onto it. Not counted as living; never dies."),
        ("PlagueRat",      "Nationless roamer. Spreads the r_ plague strain. Hunted by Warriors and Hunters."),
        ("Zombie",         "Resurrected from dead cells by a Necromancer; retains original type's appearance. Immune to Conway rules, disease, and old age; invisible to other cells' Conway neighbour counts. Permanently destroyed when killed by a Doctor, Warrior, or Hunter."),
        ("Necromancer",    "Spawns randomly. On spawn resurrects the 3 nearest dead cells as Zombies; resurrects 1 more per step. Survives only while ≥2 Zombies are alive; death kills all its Zombies."),
        ("Mutant",         "Randomly transforms into a different cell type each step. Highly unpredictable."),
    };

    private static readonly Dictionary<string, string> CellDescriptions =
        CellRules.ToDictionary(r => r.Name, r => r.Desc);

    private static readonly (string Label, string Desc)[] SimulationEvents =
    {
        ("Nations",                     "Cells in the same spawn cluster share a nationality. New cells join the nearest nation of the same colour within proximity range."),
        ("Census",                      "Every step all living cells are counted per nation. Kings and Diplomats are elected or crowned when nations reach population thresholds."),
        ("King Crowning",               "A nation with ≥5 citizens can crown a Basic cell as King. The King marks nearby Basic cells with 'toWar', promoting them to Warriors."),
        ("King-Distance Neutralisation","Basic cells further than (columns+rows)/3 from their King lose nationality and gain a 3-step neutral cooldown before they can rejoin any nation."),
        ("Diplomat Election",           "Large nations elect a Diplomat that travels to the nearest foreign nation and converts adjacent cells to its own nationality."),
        ("Revolutionary Defection",     "When one nation becomes too dominant, a member may defect and become a Revolutionary, founding a rival nation and recruiting Rebels and Warriors."),
        ("Famine",                      "Periodically kills cells in a random grid quadrant, simulating resource scarcity. Controlled by the Famine Cooldown and Famine Duration settings."),
        ("Flood",                       "Periodically wipes the outer border ring of the grid, separating nation clusters and resetting expansion pressure."),
        ("Random Life Injection",       "When population falls below the injection threshold, random cells are spawned to prevent total extinction. Threshold is set by % or absolute count."),
        ("Grid Expansion",              "Explorer cells trigger the grid to grow when they reach an edge. Growth continues up to the Max Grid Size limit."),
        ("Failure & Auto-Restart",      "The simulation ends (or auto-restarts) on: full extinction; population below Min Pop Threshold; population collapse after post-growth; or N-step stagnation."),
    };

