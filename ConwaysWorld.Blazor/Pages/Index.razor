@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@using System.Text.Json
@using System.Text.Json.Serialization

<PageTitle>Conway's World</PageTitle>

@* Inline critical CSS so it loads from the fresh DLL, bypassing app.css caching. *@
<style>
    .cw-settings-grid{display:grid;grid-template-columns:1fr 1fr;column-gap:16px}
    .cw-settings-grid>h3,.cw-settings-grid>.cw-field-full{grid-column:1/-1}
    .cw-settings-section{grid-column:1/-1}
</style>

<div class="cw-toolbar">
    <button class="@(_running ? "active" : "")" @onclick="TogglePlay">
        @(_running ? "⏸ Pause" : "▶ Play")
    </button>
    <button @onclick="StepOnce">Step</button>
    <button @onclick="Restart">↺ Restart</button>
    <button @onclick="RandomizeAndRestart">🎲 Random</button>
    <label>Speed</label>
    <input type="range" min="50" max="2000" step="50"
           value="@_intervalMs"
           @onchange="OnSpeedChange" />
    <input type="number" min="50" max="10000" step="50"
           value="@_intervalMs"
           @onchange="OnSpeedInputChange"
           style="width:64px;background:#1a1a1a;border:1px solid #333;color:#aaa;font-size:11px;padding:1px 4px;border-radius:3px;text-align:right" />
    <span style="color:#888;font-size:11px">ms</span>

    <button @onclick="() => _showSettings = true">⚙ Settings</button>
    <button @onclick="() => { _showTestCases = true; _selectedTestCase = 0; }">🧪 Test Cases</button>
    <span style="margin-left:auto;color:#666;font-size:11px">
        Gen @_model.Generation &nbsp;|&nbsp;
        Pop @_model.CurrentPopulation &nbsp;|&nbsp;
        Grid @_model.Columns×@_model.Rows
    </span>
</div>

<div class="cw-body">
    <div class="cw-main">
        <div class="cw-canvas-wrap" id="canvas-wrap">
            <canvas id="sim-canvas"></canvas>
            @if (_tooltip != null)
            {
                <div class="cw-tooltip" style="left:@(_tooltipX)px;top:@(_tooltipY)px">
                    <div class="tt-type">@_tooltip.TypeName</div>
                    <div class="tt-row">Nation @(_tooltip.Nation >= 0 ? _tooltip.Nation.ToString() : "—")</div>
                    <div class="tt-row">Age @_tooltip.Age</div>
                    @if (_tooltip.Conditions.Length > 0)
                    {
                        <div class="tt-row" style="font-size:10px;color:#777">@_tooltip.Conditions</div>
                    }
                </div>
            }
        </div>

        <div class="cw-event-bar">
            <button class="cw-log-toggle" @onclick="() => _showEventLog = !_showEventLog">
                @(_showEventLog ? "▾ Events" : "▸ Events")
                @if (_eventLog.Count > 0 && !_showEventLog)
                {
                    <span class="cw-log-badge">@_eventLog.Count</span>
                }
            </button>
        </div>
        @if (_showEventLog)
        {
            <div class="cw-event-log">
                @foreach (var ev in _eventLog)
                {
                    <div class="cw-event-entry @ev.CssClass">@ev.Message</div>
                }
            </div>
        }
    </div>

    <div class="cw-sidebar">
        <div class="cw-content-area">
            <div class="cw-panel">
                <h3>Cell Types</h3>
                <div class="cw-cell-list">
                    @foreach (var entry in _typeCounts)
                    {
                        <div class="cw-cell-row">
                            <img class="cw-cell-sprite" src="Assets/Sprites/Cell_@(entry.Name).jpg" alt="@entry.Name" />
                            <span>@entry.Name</span>
                            <span class="cw-cell-count">@entry.Count</span>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<div class="cw-nations-bar">
    @{var nlist = _model.Nations.Values.OrderBy(n => n.NationNum).ToList();}
    @for (int ni = 0; ni < nlist.Count; ni++)
    {
        var n = nlist[ni];
        if (ni > 0) { <span class="cw-nation-sep"> | </span> }
        <span class="cw-nation-count" style="color:@Cell_Nation.NationColors[n.NationNum % Cell_Nation.NationColors.Count]">@n.CitizensList.Count</span>
    }
</div>

@if (_showFailurePopup)
{
    <div class="cw-modal-overlay" @onclick="() => _showFailurePopup = false">
        <div class="cw-extinct-popup" @onclick:stopPropagation>
            <div class="cw-extinct-icon">⚠️</div>
            <div class="cw-extinct-title">Simulation Ended</div>
            <div class="cw-extinct-sub">@_failureMessage</div>
            <button class="cw-extinct-btn" @onclick="() => _showFailurePopup = false">Dismiss</button>
        </div>
    </div>
}



@if (_showSettings)
{
    <div class="cw-modal-overlay" @onclick="() => _showSettings = false">
        <div class="cw-modal" @onclick:stopPropagation>
            <div class="cw-modal-header">
                <span>Settings</span>
                <button class="cw-modal-close" @onclick="() => _showSettings = false">✕</button>
            </div>
            <div class="cw-modal-tabs">
                <button class="cw-modal-tab @(_settingsTab == 0 ? "cw-modal-tab-active" : "")"
                        @onclick="() => _settingsTab = 0">General</button>
                <button class="cw-modal-tab @(_settingsTab == 1 ? "cw-modal-tab-active" : "")"
                        @onclick="() => _settingsTab = 1">Spawn Weights</button>
                <button class="cw-modal-tab @(_settingsTab == 2 ? "cw-modal-tab-active" : "")"
                        @onclick="() => _settingsTab = 2">Hotkeys</button>
            </div>
            <div class="cw-settings-scroll">
                @if (_settingsTab == 0)
                {
                    <div class="cw-settings-grid">
                        <div class="cw-field">
                            <label>Start columns</label>
                            <input type="number" min="5" max="300" @bind="_startCols" />
                        </div>
                        <div class="cw-field">
                            <label>Start rows</label>
                            <input type="number" min="5" max="300" @bind="_startRows" />
                        </div>
                        <div class="cw-field">
                            <label>Max grid size (0 = unlimited)</label>
                            <input type="number" min="0" max="500" @bind="_maxGrid" />
                        </div>
                        <div class="cw-field">
                            <label>Max nations (1–20)</label>
                            <input type="number" min="1" max="20" @bind="_maxNations" />
                        </div>
                        <div class="cw-field">
                            <label>Start clusters (0 = MaxNations ÷ 4)</label>
                            <input type="number" min="0" max="20" @bind="_startClusters" />
                        </div>
                        <div class="cw-field">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_animationEnabled" />
                                Movement animation
                            </label>
                        </div>
                        <div class="cw-field cw-field-full">
                            <label>Initial population</label>
                            <div class="cw-pop-fields">
                                <input type="number" class="cw-pop-input" min="0" max="100" step="0.1"
                                       value="@_popPercent.ToString("F1")"
                                       @onchange="OnPopPercentChange"
                                       @onkeydown="@(e => { if (e.Key == "Enter") OnPopPercentChange(new ChangeEventArgs { Value = _popPercentStr }); })" />
                                <span class="cw-pop-sep">%</span>
                                <input type="number" class="cw-pop-input" min="0" max="@(_startCols * _startRows)"
                                       value="@_popCount"
                                       @onchange="OnPopCountChange"
                                       @onkeydown="@(e => { if (e.Key == "Enter") OnPopCountChange(new ChangeEventArgs { Value = _popCount.ToString() }); })" />
                                <span class="cw-pop-sep">/ @(_startCols * _startRows)</span>
                            </div>
                        </div>

                        <h3 class="cw-settings-section">Conway Rules</h3>
                        <div class="cw-field">
                            <label>Min neighbors (survive &amp; birth)</label>
                            <input type="number" min="0" max="7" @bind="_minNeighbors" />
                        </div>
                        <div class="cw-field">
                            <label>Max neighbors (survive)</label>
                            <input type="number" min="0" max="8" @bind="_maxNeighbors" />
                        </div>

                        <h3 class="cw-settings-section">World Events</h3>
                        <div class="cw-field">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_famineEnabled" />
                                Enable Famine
                            </label>
                        </div>
                        <div class="cw-field">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_floodEnabled" />
                                Enable Flood
                            </label>
                        </div>
                        @if (_famineEnabled)
                        {
                            <div class="cw-field">
                                <label>Min steps between famines</label>
                                <input type="number" min="1" max="500" @bind="_famineCooldown" />
                            </div>
                            <div class="cw-field">
                                <label>Famine duration (steps)</label>
                                <input type="number" min="1" max="100" @bind="_famineDuration" />
                            </div>
                        }
                        <div class="cw-field">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_randomLifeEnabled" />
                                Random Life Injection
                            </label>
                        </div>
                        <div class="cw-field">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_allowGridExpansion" />
                                Allow grid expansion
                            </label>
                        </div>
                        <div class="cw-field">
                            <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                                <input type="checkbox" @bind="_nationsEnabled" />
                                Enable nations &amp; kings
                            </label>
                        </div>

                        <h3 class="cw-settings-section cw-field-full">Failure Conditions</h3>
                        <div class="cw-field">
                            <label>Min pop threshold (0 = off)</label>
                            <input type="number" min="0" max="10000" @bind="_failurePopThreshold" />
                        </div>
                        <div class="cw-field">
                            <label>Min pop after growth (0 = off)</label>
                            <input type="number" min="0" max="10000" @bind="_failurePopAfterGrowthThreshold" />
                        </div>
                        <div class="cw-field">
                            <label>Stagnation steps (0 = off)</label>
                            <input type="number" min="0" max="500" @bind="_stagnationSteps" />
                        </div>
                    </div>
                }
                else if (_settingsTab == 1)
                {
                    <div class="cw-weights-grid">
                        @foreach (var kv in _spawnWeights)
                        {
                            <div class="cw-weight-row">
                                <img class="cw-cell-sprite" src="Assets/Sprites/Cell_@(kv.Key).jpg" alt="@kv.Key" />
                                <span class="cw-weight-name">@kv.Key</span>
                                <input type="number" min="0" max="100"
                                       value="@kv.Value"
                                       @onchange="@(e => OnWeightChange(kv.Key, e))" />
                            </div>
                        }
                    </div>
                }
                else
                {
                    <table class="cw-hotkeys-table">
                        <thead>
                            <tr><th>Key / Input</th><th>Action</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><kbd>Space</kbd></td><td>Play / Pause</td></tr>
                            <tr><td><kbd>R</kbd></td><td>Restart simulation</td></tr>
                            <tr><td><kbd>Scroll wheel</kbd></td><td>Zoom in / out</td></tr>
                            <tr><td><kbd>Right-click drag</kbd></td><td>Pan the grid</td></tr>
                            <tr><td><kbd>Double-click</kbd></td><td>Reset zoom &amp; pan</td></tr>
                            <tr><td><kbd>Left-click</kbd></td><td>Select a cell (shows events)</td></tr>
                            <tr><td><kbd>Hover</kbd></td><td>Tooltip: type, nation, age, conditions</td></tr>
                        </tbody>
                    </table>
                }
            </div>
            <div class="cw-modal-footer">
                <button class="cw-apply-btn" style="flex:1" @onclick="ApplyAndRestart">Apply & Restart</button>
                <button class="cw-apply-btn" style="flex:1;background:#555" @onclick="ResetToDefaults">Reset Defaults</button>
            </div>
        </div>
    </div>
}

@if (_showTestCases)
{
    <div class="cw-modal-overlay" @onclick="() => _showTestCases = false">
        <div class="cw-modal cw-tc-modal" @onclick:stopPropagation>
            <div class="cw-modal-header">
                <span>Test Cases</span>
                <button class="cw-modal-close" @onclick="() => _showTestCases = false">✕</button>
            </div>
            <div class="cw-tc-list">
                @for (int i = 0; i < _testCases.Count; i++)
                {
                    var tc = _testCases[i];
                    var idx = i;
                    <div class="cw-tc-row @(_selectedTestCase == idx ? "cw-tc-selected" : "")"
                         @onclick="() => _selectedTestCase = idx">
                        <div class="cw-tc-name">@tc.Name</div>
                        <div class="cw-tc-desc">@tc.Description</div>
                        @if (_selectedTestCase == idx)
                        {
                            <div class="cw-tc-detail">
                                Grid @tc.StartCols×@tc.StartRows &nbsp;·&nbsp;
                                Max @tc.MaxGrid &nbsp;·&nbsp;
                                Nations @tc.MaxNations &nbsp;·&nbsp;
                                Clusters @tc.StartClusters &nbsp;·&nbsp;
                                Pop @tc.PopCount
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="cw-modal-footer">
                <button class="cw-apply-btn" style="flex:1" @onclick="ApplyTestCase">Apply &amp; Restart</button>
                <button class="cw-apply-btn" style="flex:1;background:#555" @onclick="() => _showTestCases = false">Cancel</button>
            </div>
        </div>
    </div>
}

