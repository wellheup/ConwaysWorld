    {
        _timer.Stop();
        _running = false;

        _startCols        = 50;
        _startRows        = 50;
        _maxGrid          = 120;
        _maxNations       = 4;
        _startClusters    = 2;
        _popPercent       = 0.4;
        _popPercentStr    = "0.4";
        _popCount         = 10;
        _intervalMs       = 1000;
        _animationEnabled = true;
        _minNeighbors     = 2;
        _maxNeighbors     = 3;
        _famineEnabled    = true;
        _famineCooldown   = 15;
        _famineDuration   = 10;
        _floodEnabled       = true;
        _randomLifeEnabled            = false;
